cat > .gitignore << 'EOF'
# Flutter/Dart
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
*.g.dart

# Android
android/.gradle/
android/local.properties
android/key.properties


# APK/AAB outputs
# *.apk
# *.aab

# iOS
ios/Pods/
ios/.symlinks/

# IDE
.idea/
.vscode/
*.iml

# Misc
.DS_Store
EOF